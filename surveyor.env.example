# Surveyor API shared key — the x-surveyor-key the BER_APP tablet sends for
# cloud sync (pull confirmed jobs) AND bug-report upload.
#
# Copy this to the website's secrets dir (where deploy.py reads all secrets):
#   BERwebsite/server/secrets/surveyor.env
# then `python3 scripts/deploy.py` sets it on the stack (SurveyorAccessKey param).
#
# Use the SAME value as BER_SYNC_KEY in BER_APP/scripts/tablet.env.
# Generate one with:  openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
SURVEYOR_ACCESS_KEY=replace-with-a-strong-random-value
